import("std/env") as env
import("std/io") as io
import("std/json") as json
import("std/list") as list
import("../../../src/acp/runtime") as runtime
import("../../../src/acp/artifact") as artifact

let input = json.decode(io.read_file(env.get("ACP_INPUT_FILE").some).ok)
let s = json.decode(input.state_json)

let artifacts = if input.artifact_jsons == null then []
  else list.map(input.artifact_jsons, fn(aj) { json.decode(aj) })

runtime.dashboard(s, artifacts)
