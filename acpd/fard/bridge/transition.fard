import("std/env") as env
import("std/io") as io
import("std/json") as json
import("std/list") as list
import("std/rec") as rec
import("../../../src/acp/state") as state
import("../../../src/acp/policy") as policy
import("../../../src/acp/runtime") as runtime
import("../../../src/acp/receipt") as receipt

let input = json.decode(io.read_file(env.get("ACP_INPUT_FILE").some).ok)
let s = json.decode(input.state_json)
let pol = policy.default_enterprise_policy()
let actor_rec = runtime.actor(input.actor.actor_id, input.actor.roles)

let patches = if rec.has(input, "patches") then input.patches else []

let result = runtime.human_state_edit(actor_rec, s, pol, patches)

{
  ok: result.ok,
  state_json: json.encode(result.state),
  state_hash: receipt.digest(result.state),
  receipt_json: json.encode(result.receipt),
  receipt_digest: result.receipt.digest,
  policy_ok: result.policy.ok,
  violations: result.policy.violations,
  seq: result.state.seq,
  stage: result.state.stage
}
