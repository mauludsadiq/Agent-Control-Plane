import("../src/acp/autonomy") as autonomy
import("../src/acp/state") as state
import("../src/acp/policy") as policy
import("../src/acp/runtime") as runtime
import("../src/acp/receipt") as receipt
import("std/list") as list
import("std/rec") as rec
import("std/str") as str

fn make_receipts(actor_id, count, kind) {
  list.build(count, fn(i) {
    {
      receipt_type: "acp.state_transition.v1",
      workflow_id: "wf_auto",
      seq: i + 1,
      kind: kind,
      actor: actor_id,
      state_before_hash: receipt.digest({ seq: i }),
      input_hash: receipt.digest({ i: i }),
      policy_version: "ACP-POLICY-1.0.0",
      policy_digest: receipt.digest("ACP-POLICY-1.0.0"),
      tool_version: "human",
      tool_digest: receipt.digest("human"),
      artifact_digests: [],
      state_after_hash: receipt.digest({ seq: i + 1 }),
      digest: receipt.digest({ seq: i + 1, actor: actor_id })
    }
  })
}

fn make_artifacts(actor_id, count, confidence) {
  list.build(count, fn(i) {
    { name: str.concat(["artifact_", str.from(i)]), producer: actor_id, confidence: confidence, digest: receipt.digest({ i: i, actor: actor_id }) }
  })
}

test "new agent with no receipts is restricted" {
  let r = autonomy.score("agent:new", [], [], 0) in
  r.level == autonomy.LEVEL_RESTRICTED && r.total_receipts == 0
}

test "agent with few receipts stays restricted regardless of pass rate" {
  let receipts = make_receipts("agent:1", 2, "artifact_committed") in
  let artifacts = make_artifacts("agent:1", 2, 95) in
  let r = autonomy.score("agent:1", receipts, artifacts, 0) in
  r.level == autonomy.LEVEL_RESTRICTED
}

test "agent with enough receipts and high confidence reaches supervised" {
  let receipts = make_receipts("agent:1", 5, "artifact_committed") in
  let artifacts = make_artifacts("agent:1", 5, 90) in
  let r = autonomy.score("agent:1", receipts, artifacts, 0) in
  r.level == autonomy.LEVEL_SUPERVISED
}

test "agent with violations is demoted to restricted" {
  let good = make_receipts("agent:1", 20, "artifact_committed") in
  let bad = make_receipts("agent:1", 3, "policy_violation") in
  let artifacts = make_artifacts("agent:1", 20, 90) in
  let r = autonomy.score("agent:1", list.concat([good, bad]), artifacts, 0) in
  r.level == autonomy.LEVEL_RESTRICTED
}

test "strong agent reaches standard level" {
  let receipts = make_receipts("agent:1", 15, "artifact_committed") in
  let artifacts = make_artifacts("agent:1", 15, 90) in
  let r = autonomy.score("agent:1", receipts, artifacts, 0) in
  r.level == autonomy.LEVEL_STANDARD
}

test "allowed tools expand with level" {
  let restricted_tools = autonomy.allowed_tools_for_level(autonomy.LEVEL_RESTRICTED) in
  let standard_tools = autonomy.allowed_tools_for_level(autonomy.LEVEL_STANDARD) in
  let autonomous_tools = autonomy.allowed_tools_for_level(autonomy.LEVEL_AUTONOMOUS) in
  list.len(restricted_tools) < list.len(standard_tools) &&
  list.len(standard_tools) < list.len(autonomous_tools)
}

test "spend limit grows with level" {
  autonomy.spend_limit_for_level(autonomy.LEVEL_RESTRICTED) == 0 &&
  autonomy.spend_limit_for_level(autonomy.LEVEL_SUPERVISED) < autonomy.spend_limit_for_level(autonomy.LEVEL_STANDARD) &&
  autonomy.spend_limit_for_level(autonomy.LEVEL_STANDARD) < autonomy.spend_limit_for_level(autonomy.LEVEL_EXTENDED) &&
  autonomy.spend_limit_for_level(autonomy.LEVEL_EXTENDED) < autonomy.spend_limit_for_level(autonomy.LEVEL_AUTONOMOUS)
}

test "human override caps autonomy level" {
  let receipts = make_receipts("agent:1", 15, "artifact_committed") in
  let artifacts = make_artifacts("agent:1", 15, 90) in
  let r = autonomy.score("agent:1", receipts, artifacts, 0) in
  let s0 = state.new_workflow("wf_auto", "test", "ops") in
  let capped_state = state.apply_patches(s0, [{ path: "var.autonomy.agent:1", value: { max_level: autonomy.LEVEL_SUPERVISED } }]) in
  let overridden = autonomy.override_level(r, capped_state) in
  overridden.level == autonomy.LEVEL_SUPERVISED && overridden.override_applied
}

test "human override floors autonomy level" {
  let r = autonomy.score("agent:new", [], [], 0) in
  let s0 = state.new_workflow("wf_auto", "test", "ops") in
  let elevated_state = state.apply_patches(s0, [{ path: "var.autonomy.agent:new", value: { min_level: autonomy.LEVEL_SUPERVISED } }]) in
  let overridden = autonomy.override_level(r, elevated_state) in
  overridden.level == autonomy.LEVEL_SUPERVISED && overridden.override_applied
}

test "evaluate_with_autonomy passes for tool within autonomy level" {
  let pol = policy.default_enterprise_policy() in
  let s0 = state.new_workflow("wf_auto", "test", "ops") in
  let a = runtime.actor("agent:1", ["agent"]) in
  let receipts = make_receipts("agent:1", 15, "artifact_committed") in
  let artifacts = make_artifacts("agent:1", 15, 90) in
  let r = autonomy.score("agent:1", receipts, artifacts, 0) in
  let result = autonomy.evaluate_with_autonomy(pol, s0, a, { tool: "write_artifact" }, r) in
  result.ok
}

test "evaluate_with_autonomy blocks tool above autonomy level" {
  let pol = policy.default_enterprise_policy() in
  let s0 = state.new_workflow("wf_auto", "test", "ops") in
  let a = runtime.actor("agent:new", ["agent"]) in
  let r = autonomy.score("agent:new", [], [], 0) in
  let result = autonomy.evaluate_with_autonomy(pol, s0, a, { tool: "write_artifact" }, r) in
  !result.ok
}

test "summary returns readable autonomy card" {
  let receipts = make_receipts("agent:1", 15, "artifact_committed") in
  let artifacts = make_artifacts("agent:1", 15, 90) in
  let r = autonomy.score("agent:1", receipts, artifacts, 0) in
  let s = autonomy.summary(r) in
  s.actor_id == "agent:1" && s.level_name == "standard" && s.tool_count > 1
}

test "autonomy record only counts receipts for the target actor" {
  let agent1_receipts = make_receipts("agent:1", 15, "artifact_committed") in
  let agent2_receipts = make_receipts("agent:2", 50, "artifact_committed") in
  let all_receipts = list.concat([agent1_receipts, agent2_receipts]) in
  let artifacts = make_artifacts("agent:1", 15, 90) in
  let r = autonomy.score("agent:1", all_receipts, artifacts, 0) in
  r.total_receipts == 15
}
